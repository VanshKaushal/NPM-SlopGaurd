{
  "maxRiskScore": 30,
  "blockHallucinatedPackages": true,
  "allowInstallScripts": "block",
  "requireProvenance": true,
  "maxDependencyDepth": 15,
  "blockNewPackages": true,
  "minimumConfidence": "high",
  "allowSubstringMatching": false,
  "allowMutableGitRefs": false,
  "requireLockfile": true,
  "allowedRegistries": ["https://registry.npmjs.org"],
  "blockOnCircuitOpen": true,
  "minPublisherAgeDays": 90,
  "minVersionAgeDays": 7
}
