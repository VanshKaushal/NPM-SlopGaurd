{
  "name": "fintech-policy",
  "strictness": "paranoid",
  "requireProvenance": true,
  "allowPreReleases": false,
  "allowUnsigned": false,
  "allowedRegistries": ["https://registry.npmjs.org"],
  "bannedLicenses": ["GPL-3.0"],
  "maxGraphSize": 10000,
  "auditRequirements": {
